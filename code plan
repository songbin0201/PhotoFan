# 将视觉分析结果 → 自然语言建议

SUGGESTION_TEMPLATES = {
    "lighting_dark":       "画面偏暗，试试点击屏幕调整曝光",
    "lighting_overexposed":"画面过曝，减少曝光补偿",
    "lighting_backlit":    "逆光拍摄，可以开启 HDR 或换个角度",
    "composition_left":    "主体偏左，向右移动一些构图更好",
    "composition_right":   "主体偏右，向左移动试试",
    "composition_center":  "主体居中，稍微偏离中心构图更有层次",
    "stability_blur":      "画面模糊，请稳住手机",
    "stability_shake":     "轻微抖动，深呼吸后再按快门",
    "focus_miss":          "对焦跑偏了，点击主体重新对焦",
    "focus_adjusting":     "等待对焦完成...",
    "tilt":                "手机倾斜了，请保持水平",
    "lens_dirty":          "镜头可能有污渍，擦拭后画质更好",
}

def plan(vision_result, sensor_result, active_ids) -> list[Suggestion]:
    suggestions = []

    # 从视觉分析 + 传感器生成候选建议
    candidates = _extract_candidates(vision_result, sensor_result)

    # 过滤已在屏幕上的建议，按 severity 排序
    filtered = [c for c in candidates if c.id not in active_ids]
    filtered.sort(key=lambda x: x.priority, reverse=True)

    # 最多推送 3 条新建议（避免弹幕过多）
    return filtered[:3]
```

