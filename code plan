### 4. Agent 调度核心 `agents/orchestrator.py`

```python
# orchestrator.py

async def run(request: AnalyzeRequest) -> AsyncGenerator[str, None]:

    # Step 1: 图像预处理
    image = decode_and_preprocess(request.frame)

    # Step 2: 并行执行视觉分析 + 传感器判断
    vision_result, sensor_result = await asyncio.gather(
        vision_analyzer.analyze(image),
        resolve_detector.check_sensors(request.sensor_data)
    )

    # Step 3: 判断哪些已有建议可以标记为 resolved
    for suggestion_id in request.active_suggestions:
        if resolve_detector.is_resolved(suggestion_id, vision_result, sensor_result):
            yield format_sse("resolve", {"id": suggestion_id})

    # Step 4: 生成新建议（排除已有的，避免重复）
    new_suggestions = suggestion_planner.plan(
        vision_result=vision_result,
        sensor_result=sensor_result,
        active_ids=request.active_suggestions
    )

    # Step 5: 流式逐条推送建议
    for suggestion in new_suggestions:
        yield format_sse("suggestion", suggestion.dict())
        await asyncio.sleep(0.3)    # 错开推送，让弹幕依次飘出

    yield format_sse("done", {})
```

